# Anthropic Claude API
# Used by: agents/scout/classifier (next session)
ANTHROPIC_API_KEY=

# Reddit API
# Register at https://www.reddit.com/prefs/apps once Reddit approves the access request.
# Pick "script" type. Redirect URI can be http://localhost:8080 (unused).
# Used by: agents/scout/fetchers/reddit.py
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=kl-scout/0.1 by u/SparkyMcCrinkle

# YouTube Data API v3
# Create a project at https://console.cloud.google.com, enable YouTube Data API v3,
# create an API key. Free tier 10,000 quota units/day.
# Used by: agents/scout/fetchers/youtube.py
YOUTUBE_API_KEY=

# Supabase
# Service role key is required because Scout writes from a server-side context.
# Anon/publishable key will not have permission to insert into agent_runs or classified_posts.
# Used by: shared/db/client.py
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Schema selector
# Set to agents_dev for local development, agents_prod when running scheduled.
SUPABASE_SCHEMA=agents_dev
